{
  "manifest_version": 3,
  "name": "CookieWise",
  "version": "1.0.0",
  "description": "Automatically detects cookie consent banners on websites and alerts you.",
  "permissions": [
    "notifications",
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "js/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "CookieWise – Cookie Banner Detector"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "html/risk-score.html",
        "html/data-flow-map.html",
        "html/threat-scan.html",
        "html/default-cookie-settings.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
